# VerveQ Platform Production Environment Configuration Template
# Copy this file to .env.production and fill in actual values
# NEVER commit files with real secrets to version control

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================

# Environment: production
ENVIRONMENT=production
NODE_ENV=production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL (Recommended for production)
DATABASE_URL=postgresql://username:password@localhost:5432/verveq_prod

# Or SQLite (for smaller deployments)
# DATABASE_URL=sqlite:///path/to/production.db

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret Key (CRITICAL: Generate a strong random string, minimum 32 characters)
JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS

# Session Secret (Generate a different secure random string)
SESSION_SECRET=CHANGE_THIS_TO_ANOTHER_SECURE_RANDOM_STRING

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com

# =============================================================================
# REDIS CONFIGURATION (Optional)
# =============================================================================

# Redis URL for caching (uncomment if using Redis)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# EXTERNAL API KEYS (Add as needed)
# =============================================================================

# Email service (if using SendGrid)
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# AWS services (if using AWS)
# AWS_ACCESS_KEY_ID=your_aws_access_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
# AWS_REGION=us-east-1

# Analytics/Monitoring (if using Sentry)
# SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# FEATURE CONFIGURATION
# =============================================================================

# Enable/disable caching
ENABLE_CACHE=true

# Enable/disable analytics
ENABLE_ANALYTICS=false

# Debug mode (should be false in production)
DEBUG=false

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port to run the server on
PORT=8000

# Host to bind to
HOST=0.0.0.0

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================

# 1. Copy this file to .env.production
# 2. Replace all placeholder values with real production values
# 3. Generate secure random strings for JWT_SECRET_KEY and SESSION_SECRET
# 4. Never commit the .env.production file to version control
# 5. Use environment-specific secrets management in production when possible