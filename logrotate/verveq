# VerveQ Platform Log Rotation Configuration
# Place this file in /etc/logrotate.d/verveq

# PM2 Application Logs
/var/www/verveq/logs/*.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 644 verveq verveq
    postrotate
        # Reload PM2 logs after rotation
        su verveq -c "pm2 reloadLogs" > /dev/null 2>&1 || true
    endscript
}

# Nginx Logs (if using our nginx config)
/var/log/nginx/verveq-*.log {
    daily
    missingok
    rotate 52
    compress
    delaycompress
    notifempty
    create 644 www-data adm
    sharedscripts
    prerotate
        if [ -d /etc/logrotate.d/httpd-prerotate ]; then \
            run-parts /etc/logrotate.d/httpd-prerotate; \
        fi
    endscript
    postrotate
        # Reload nginx after log rotation
        systemctl reload nginx > /dev/null 2>&1 || true
    endscript
}

# System logs for VerveQ (if using systemd services)
/var/log/verveq/*.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 644 verveq verveq
    postrotate
        # Signal systemd to reopen log files
        systemctl kill --signal=USR1 verveq-backend.service || true
        systemctl kill --signal=USR1 verveq-frontend.service || true
    endscript
}

# Database backup logs (if created)
/var/log/verveq/backup-*.log {
    weekly
    missingok
    rotate 12
    compress
    delaycompress
    notifempty
    create 644 verveq verveq
}

# Deployment logs
/var/log/verveq/deploy-*.log {
    weekly
    missingok
    rotate 24
    compress
    delaycompress
    notifempty
    create 644 verveq verveq
}