# VerveQ Frontend Environment Variables
# Copy this file to .env.local and customize for your environment

# Development server configuration
VITE_DEV_PORT=3000
VITE_PREVIEW_PORT=3001

# Backend API configuration
VITE_API_BASE_URL=http://localhost:8008
VITE_API_TIMEOUT=10000

# Feature flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG_MODE=false
VITE_ENABLE_SERVICE_WORKER=true

# Build configuration
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true

# Application metadata
VITE_APP_NAME=VerveQ
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=Ultimate Football Knowledge Challenge

# Database Configuration
DATABASE_URL=postgresql://footquizz_user:footquizz2024!@localhost:5432/footquizz_db

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379/0

# Security Configuration
SECRET_KEY=your-secure-secret-key-replace-this-in-production

# Application Configuration
ENABLE_POSTGRESQL=true
FALLBACK_TO_JSON=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
CACHE_TTL=3600

# Production Security Settings
VERVEQ_DEBUG=false
VERVEQ_ENABLE_CORS=true
VERVEQ_ENABLE_RATE_LIMITING=true
VERVEQ_RATE_LIMIT_REQUESTS=100
VERVEQ_RATE_LIMIT_WINDOW=60

# Migration Configuration
MIGRATION_BATCH_SIZE=1000
MIGRATION_LOG_LEVEL=INFO
