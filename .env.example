# Environment Configuration
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# Database Configuration
#DATABASE_URL=postgresql://user:pass@localhost:5432/verveq_db
SQLITE_PATH=verveq_platform.db

# Security Configuration
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000,http://localhost:19006
CORS_ALLOW_CREDENTIALS=true

# API Configuration
API_TITLE=VerveQ Platform API
API_VERSION=3.0.0
API_DESCRIPTION="A comprehensive competitive sports gaming platform."

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000

# Optional Cache Configuration (MVP Features)
#REDIS_URL=redis://localhost:6379
ENABLE_CACHE_BACKEND=false

# Clerk Configuration
# NOTE: Generate fresh Clerk keys and store them securely (do not commit real values).
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_JWT_AUDIENCE=your-clerk-jwt-audience
CLERK_WEBHOOK_SECRET=your-clerk-webhook-secret

# Frontend Clerk (set in frontend env):
VITE_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
REACT_APP_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
