{
  "name": "verveq-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "codegen": "node scripts/ensureConvexGenerated.mjs",
    "predev": "npm run codegen",
    "dev": "vite",
    "prebuild": "npm run codegen",
    "build": "vite build",
    "prebuild:dev": "npm run codegen",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "gameplay:curated": "npx tsx ../scripts/runCuratedGameplayWorkflow.ts",
    "gameplay:curated-parity": "npx tsx ../scripts/runCuratedParityWorkflow.ts",
    "gameplay:curated-parity:status": "npx tsx ../scripts/runCuratedParityWorkflow.ts --status",
    "gameplay:curated-parity:inspect": "npx tsx ../scripts/runCuratedParityWorkflow.ts --inspect",
    "gameplay:curated-parity:approve": "npx tsx ../scripts/runCuratedParityWorkflow.ts --approve",
    "gameplay:smoke": "npx tsx ../scripts/runCuratedGameplaySmoke.ts",
    "content:qa": "npx tsx scripts/contentQaCli.ts",
    "content:qa:baseline": "npx tsx scripts/contentQaBaseline.ts",
    "learn:graph:validate": "npx tsx scripts/validateLearnSkillGraph.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@radix-ui/react-dialog": "^1.1.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.40.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "react-router-dom": "^6.30.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
